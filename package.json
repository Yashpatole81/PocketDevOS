{
  "name": "pocketdevos",
  "version": "0.1.0",
  "description": "AI-native dev workspace for Android via Termux",
  "license": "Apache-2.0",
  "author": "ztpaysa",
  "type": "module",
  "bin": {
    "pocketdevos": "./bin/pocketdevos.js"
  },
  "files": [
    "server/",
    "client/",
    "dist/",
    "bin/",
    "scripts/"
  ],
  "scripts": {
    "dev": "concurrently \"tsx watch server/src/index.ts\" \"vite --config client/vite.config.ts\"",
    "build": "vite build --config client/vite.config.ts && tsup server/src/index.ts --format esm --outDir dist/server",
    "start": "node dist/server/index.js",
    "typecheck": "tsc --build"
  },
  "dependencies": {
    "fastify": "5.3.3",
    "@fastify/cors": "11.0.1",
    "@fastify/static": "8.1.0",
    "@fastify/websocket": "11.0.2",
    "ws": "8.18.2",
    "chokidar": "4.0.3",
    "zod": "3.25.76",
    "nanoid": "5.1.5",
    "ai": "4.3.16",
    "@ai-sdk/openai-compatible": "0.2.14",
    "eventsource-parser": "3.0.1",
    "@codemirror/autocomplete": "6.18.6",
    "@codemirror/commands": "6.8.1",
    "@codemirror/lang-css": "6.3.1",
    "@codemirror/lang-html": "6.4.9",
    "@codemirror/lang-javascript": "6.2.3",
    "@codemirror/lang-json": "6.0.1",
    "@codemirror/lang-markdown": "6.3.2",
    "@codemirror/lang-python": "6.1.7",
    "@codemirror/search": "6.5.10",
    "@codemirror/state": "6.5.2",
    "@codemirror/view": "6.36.5",
    "@uiw/codemirror-theme-tokyo-night": "4.23.7",
    "@uiw/react-codemirror": "4.23.7",
    "@xterm/addon-fit": "0.10.0",
    "@xterm/addon-search": "0.15.0",
    "@xterm/addon-web-links": "0.11.0",
    "@xterm/addon-webgl": "0.18.0",
    "@xterm/xterm": "5.5.0",
    "clsx": "2.1.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-markdown": "9.0.3",
    "react-resizable-panels": "2.1.7",
    "tailwind-merge": "3.5.0",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "concurrently": "9.1.2",
    "typescript": "5.8.3",
    "tsx": "4.19.4",
    "tsup": "8.5.0",
    "@types/node": "22.15.21",
    "@types/ws": "8.18.1",
    "@tailwindcss/vite": "4.2.3",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "@vitejs/plugin-react": "4.6.0",
    "tailwindcss": "4.2.3",
    "vite": "7.0.4"
  }
}
